{
  "manifest_version": 3,
  "name": "Tracker Watch",
  "description": "Zeigt alle aktiven Tracker und Cookies jeder Website – inkl. welche Daten gesendet werden.",
  "version": "1.0.0",
  "permissions": [
    "webRequest",
    "cookies",
    "storage",
    "tabs",
    "webNavigation",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": [],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Tracker Watch"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["sidebar.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
