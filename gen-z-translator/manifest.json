{
  "manifest_version": 3,
  "name": "Text-Transformer — 15 Modi für deutschen Text",
  "version": "3.0.0",
  "description": "Verwandelt deutschen Text in Gen-Z, Bildungssprache, 7 Dialekte, Politiker-Sprech, Barock-Deutsch, Gender-Varianten oder streicht alle Adjektive — mit behutsamer Drei-Akt-Dramaturgie und grammatikbewusster Ersetzung",
  "permissions": ["activeTab", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": [
        "js/grammar.js",
        "js/dictionary.js",
        "js/emojis.js",
        "js/fillers.js",
        "js/transformer.js",
        "js/formal-dictionary.js",
        "js/formal-fillers.js",
        "js/formal-transformer.js",
        "js/dialects.js",
        "js/dialect-transformer.js",
        "js/special-modes.js",
        "js/content.js"
      ],
      "css": ["css/overlay.css"],
      "run_at": "document_idle"
    }
  ]
}
